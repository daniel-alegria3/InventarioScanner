{
  "name": "InventarioScanner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vue-tsc && vite build",
    "build:github": "cross-env VITE_BASE_URL=/InventarioScanner/ npm run build",
    "deploy": "npm run build:github && gh-pages -d dist",
    "preview": "vite preview",
    "test:e2e": "cypress run",
    "test:unit": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor-mlkit/barcode-scanning": "^8.1.0",
    "@capacitor/android": "^8.0.0",
    "@capacitor/app": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/keyboard": "^8.0.0",
    "@capacitor/share": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "@capawesome/capacitor-file-picker": "^8.0.2",
    "@ionic/vue": "^8.4.1",
    "@ionic/vue-router": "^8.0.0",
    "barcode-detector": "^3.0.6",
    "ionicons": "^8.0.13",
    "vue": "^3.5.13",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.3.0",
    "cross-env": "^10.1.0",
    "cypress": "^15.16.0",
    "eruda": "^3.4.3",
    "eslint": "^8.35.0",
    "eslint-plugin-vue": "^9.9.0",
    "gh-pages": "^6.3.0",
    "jsdom": "^22.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.3"
  },
  "description": "An Ionic project"
}
